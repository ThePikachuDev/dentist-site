---
import background from "../assets/background.svg";
---

<div id="container">
    <img
        class="w-screen h-screen"
        id="background"
        src={background.src}
        alt=""
        fetchpriority="high"
    />

    <div class="heroPage w-screen h-screen flex max-lg:flex-col max-lg:gap-2">
        <div
            class="leftHero lg:w-1/2 h-screen pl-14 pr-26 text-left flex flex-col pt-24"
        >
            <h1
                class="sm:mr-20 max-sm:font-semibold max-sm:text-4xl max-sm:leading-12 md:mr-0 lg:text-[min(10vw,60px)] text-7xl tracking-wide leading-[4.5rem] font-medium"
            >
                Your smile, our passion, experience dentistry like never before!
            </h1>
            <div class="heroLine mt-6 w-[150px] h-[2px] bg-black"></div>

            <p class="font-light mt-5 text-xl">
                Providing advanced dental solutions with a gentle touch. From
                preventive care to implants, we ensure your best smile.
            </p>
            <button
                class="px-6 py-3 cursor-pointer mt-6 w-fit rounded-2xl bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-semibold text-lg shadow-lg transform transition duration-300 ease-in-out hover:scale-105 hover:shadow-2xl hover:brightness-110"
            >
                Click Me
            </button>
        </div>
        <div class="rightHero lg:w-1/2 h-screen">
            <img
                class="w-full object-cover h-[320px] md:h-full rounded-lg"
                src="/hero.JPG"
                alt=""
            />
        </div>
    </div>
</div>

<style>
    #background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        filter: blur(100px);
    }
</style>
